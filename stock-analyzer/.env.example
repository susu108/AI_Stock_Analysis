DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=你的token
DINGTALK_SECRET=SEC你的密钥
# 石油板块短线专属钉钉群
DINGTALK_WEBHOOK_OIL=https://oapi.dingtalk.com/robot/send?access_token=石油群token
DINGTALK_SECRET_OIL=SEC石油群密钥
STOCK_CODE=301075
STOCK_NAME=多瑞生物
STOCK_MARKET=sz
PUSH_TIME=09:00
PUSH_TIMES=09:00,11:30,14:30
# false=仅定时或 python main.py --now 推送；true=启动即推送一次（易误触）
MANUAL_RUN=false
# false=不在本地常驻调度（推荐，配合 cron-job.org → GitHub Actions）
ENABLE_LOCAL_SCHEDULER=false
KLINE_DAYS=60
LOG_LEVEL=INFO

# 持仓配置（JSON 数组，account=账户名 cost=成本价 shares=股数）
POSITIONS=[{"account":"账户A","cost":167.955,"shares":100},{"account":"账户B","cost":63.38,"shares":800}]

# DeepSeek 大模型（买卖建议 + 持仓分析 + 资讯解读 + 涨跌归因）
DEEPSEEK_API_KEY=sk-你的deepseek密钥
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_ENABLED=true

# 联网搜索（涨跌归因政策资讯补全，可选 Tavily / Serper）
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=tvly-你的密钥
WEB_SEARCH_CACHE_HOURS=4
# 同行催化剂监控（可选，覆盖默认迪哲医药,哈药股份,...）
# SECTOR_PEER_WATCH=迪哲医药,哈药股份,恒瑞医药

# 个股题材关键词（用于联网搜索 query）
STOCK_THEMES=GLP-1,司美格鲁肽,多肽原料药

STOCK_BUSINESS=主营补液注射液，集采后营收大幅萎缩；多肽/GLP-1业务刚起步、营收占比低、无海外长期大额订单，无法扭转亏损；2025全年归母净亏损1.02亿、2026Q1营收同比下滑34.41%且续亏1396.8万元，8月26日披露中报存在业绩暴雷预期，无机构长线持仓，仅短线游资题材炒作

# 多股监控（JSON 数组，配置后优先于上方单股 STOCK_*）
# 每项：code/name/market/themes/business/positions；positions 可留空 []
# 示例：医药 pharma（多瑞/诚达/富祥）+ 有色 nonferrous（神火/云铝）；石油 oil_short 已停用
STOCK_PROFILES=[{"code":"301075","name":"多瑞生物","market":"sz","themes":["GLP-1","司美格鲁肽","多肽原料药"],"business":"主营补液注射液，集采后营收大幅萎缩；多肽/GLP-1业务刚起步、营收占比低、无海外长期大额订单，无法扭转亏损；2025全年归母净亏损1.02亿、2026Q1营收同比下滑34.41%且续亏1396.8万元，8月26日披露中报存在业绩暴雷预期，无机构长线持仓，仅短线游资题材炒作","positions":[{"account":"账户A","cost":167.955,"shares":100},{"account":"账户B","cost":63.38,"shares":800}],"channel":"default","group":"pharma","group_label":""},{"code":"301201","name":"诚达药业","market":"sz","themes":["CDMO","左旋肉碱","GLP-1多肽减肥药","CGT","基因治疗","医药中间体","创新药"],"business":"主营GLP-1多肽减肥药、CGT基因治疗医药中间体CDMO+左旋肉碱原料，手握海外药企长期定点批量订单，产能满负荷投产，为第二增长核心；2025年小幅亏损、2026Q1营收同比+68.06%且归母净利润同比大增600.15%实现扭亏，半年报预增580%-780%，无持续亏损风险；负债率仅9.78%，财务结构稳健，多家公募机构长期持仓，唯一隐患是业务高度依赖GLP-1赛道，行业扩产潮或远期引发中间体价格竞争","positions":[],"channel":"default","group":"pharma","group_label":""},{"code":"300497","name":"富祥股份","market":"sz","themes":["GLP-1","多肽中间体","抗感染原料药","电解液","VC添加剂","FEC","新能源"],"business":"双主线经营：1.医药板块GLP-1多肽中间体、抗感染原料药，拥有FDA/CEP海外药企认证，稳定供货辉瑞、默克，减肥药海外订单持续放量；2.新能源电解液VC/FEC添加剂，1万吨VC产能，动力电池+储能需求带动量价齐升；2026上半年预盈1.65-2.15亿，同比扭亏大增2487%-3204%，扣非净利润全部来自主业经营，无资产处置虚增利润；2025年同期亏损造就超高增速，存在股东减持计划；风险：GLP1、电解液赛道均为强周期，行业扩产潮远期压低产品毛利率，短期以游资短线交易为主，长线机构持仓较少。","positions":[],"channel":"default","group":"pharma","group_label":""},{"code":"000933","name":"神火股份","market":"sz","themes":["电解铝","煤炭","氧化铝","有色"],"business":"煤铝双主线，煤炭稳定现金流，电解铝产能持续释放，半年报利润大幅预增；底部箱体震荡，北向资金持续加仓；风险：煤炭价格波动，铝周期回调。","positions":[],"channel":"default","group":"nonferrous","group_label":"有色周期"},{"code":"000807","name":"云铝股份","market":"sz","themes":["电解铝","氧化铝","有色","云南水电铝"],"business":"水电电解铝龙头，90万吨产能，丰水期成本行业最低；半年报预增170%+，电解铝产能红线锁供给，光伏/新能源车拉动铝需求；风险：沪铝期货下跌压缩利润，上方前期高点套牢盘。","positions":[],"channel":"default","group":"nonferrous","group_label":"有色周期"}]

# 涨跌幅低于该阈值且无量能异常时，涨跌归因输出简版
PRICE_MOVE_MIN_PCT=2.0

# 钉钉报告：compact=分析结论优先（默认）；full=完整长报告
DINGTALK_REPORT_MODE=compact

